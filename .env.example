# ── Google Drive Integration ──────────────────────────────────────────────────
# Get your Client ID from https://console.cloud.google.com/
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here

# ── AI Provider Configuration ─────────────────────────────────────────────────
# Select your AI provider: anthropic (default) or openai
AI_PROVIDER=anthropic

# Anthropic Claude API key — get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI API key (if using AI_PROVIDER=openai)
OPENAI_API_KEY=sk-...

# Optional: OpenRouter or custom base URL (for AI_PROVIDER=openai)
# AI_BASE_URL=https://openrouter.ai/api/v1

# Optional: override the default model
# Anthropic default: claude-haiku-4-5-20251001
# OpenAI default: gpt-4o-mini
# AI_MODEL=claude-haiku-4-5-20251001
